#!/bin/bash

set -euo pipefail

log_path="/Users/aaron/Repos/github.com/scripts/.cursor/debug-d6faa6.log"

debug_log() {
    # #region agent log
    local run_id="$1"
    local hypothesis_id="$2"
    local location="$3"
    local message="$4"
    local data_json="$5"
    local ts
    ts="$(date +%s%3N 2>/dev/null || printf '%s000' "$(date +%s)")"
    printf '{"sessionId":"d6faa6","runId":"%s","hypothesisId":"%s","location":"%s","message":"%s","data":%s,"timestamp":%s}\n' \
        "$run_id" "$hypothesis_id" "$location" "$message" "$data_json" "$ts" >> "$log_path"
    # #endregion
}

show_all=false

while [[ $# -gt 0 ]]; do
    case "$1" in
        -a|--all)
            show_all=true
            shift
            ;;
        -*)
            echo "ghls: unknown option: $1" >&2
            echo "usage: ghls [-a|--all]" >&2
            exit 1
            ;;
        *)
            echo "ghls: unexpected argument: $1" >&2
            echo "usage: ghls [-a|--all]" >&2
            exit 1
            ;;
    esac
done

if ! command -v gh >/dev/null 2>&1; then
    echo "ghls: GitHub CLI 'gh' is required but not installed." >&2
    exit 1
fi

if ! command -v jq >/dev/null 2>&1; then
    echo "ghls: 'jq' is required but not installed." >&2
    exit 1
fi

if ! command -v git >/dev/null 2>&1; then
    echo "ghls: 'git' is required but not installed." >&2
    exit 1
fi

color_enabled=false
if [[ -t 1 ]]; then
    color_enabled=true
fi

if $color_enabled; then
    c_clean=$'\e[32m'
    c_dirty=$'\e[33m'
    c_notcloned=$'\e[2m'
    c_reset=$'\e[0m'
else
    c_clean=""
    c_dirty=""
    c_notcloned=""
    c_reset=""
fi

width_status=10
width_name=40
width_updated=14

current_user="$(gh api user -q .login 2>/dev/null || true)"
if [[ -z "$current_user" ]]; then
    echo "ghls: unable to determine current GitHub user (is 'gh' authenticated?)." >&2
    exit 1
fi

if $show_all; then
    cutoff_iso=""
else
    if date -v-6m +%Y-%m-%dT%H:%M:%SZ >/dev/null 2>&1; then
        cutoff_iso="$(date -v-6m +%Y-%m-%dT%H:%M:%SZ)"
    elif date -d '6 months ago' +%Y-%m-%dT%H:%M:%SZ >/dev/null 2>&1; then
        cutoff_iso="$(date -d '6 months ago' +%Y-%m-%dT%H:%M:%SZ)"
    else
        cutoff_iso=""
    fi
fi

# Determine date handling for formatting UPDATED column.
date_mode="raw"
if date -j -f "%Y-%m-%dT%H:%M:%SZ" "1970-01-01T00:00:00Z" +%s >/dev/null 2>&1; then
    date_mode="bsd"
elif date -d "1970-01-01T00:00:00Z" +%s >/dev/null 2>&1; then
    date_mode="gnu"
fi

if date +%s >/dev/null 2>&1; then
    now_epoch="$(date +%s)"
else
    now_epoch=0
fi

debug_log "run1" "H1" "ghls:cutoff" "cutoff computed" "$(printf '{"showAll":%s,"cutoffIso":"%s"}' \
    "$($show_all && echo true || echo false)" "$cutoff_iso")"

gh_json="$(gh repo list --json name,description,updatedAt,owner,isPrivate,pushedAt --limit 1000 2>/dev/null || true)"
if [[ -z "$gh_json" ]]; then
    echo "ghls: failed to fetch repositories via 'gh repo list'." >&2
    exit 1
fi

prefix="${gh_json:0:80}"
prefix="${prefix//$'\n'/ }"
prefix_escaped="${prefix//\"/\\\"}"

# Always sort all GitHub repos by updatedAt; cutoff is applied later in bash
# only for remote-only repos (those without a local clone).
jq_program='sort_by(.updatedAt) | reverse | .[]'

debug_log "run1" "H1" "ghls:gh_json" "gh_json snapshot" "$(printf '{"length":%s,"prefix":"%s","jqProgram":"%s"}' \
    "${#gh_json}" "$prefix_escaped" "$jq_program")"

printf "%-${width_status}s %-${width_name}s %-${width_updated}s\n" "STATUS" "NAME" "UPDATED"
printf "%0.s-" $(seq 1 $((width_status + width_name + width_updated + 2)))
printf "\n"

format_updated() {
    local iso="$1"

    if [[ "$date_mode" != "bsd" && "$date_mode" != "gnu" ]]; then
        printf "%s" "$iso"
        return
    fi

    local epoch=""
    if [[ "$date_mode" == "bsd" ]]; then
        # Normalize timezone offsets with a colon (e.g., -06:00 -> -0600) for BSD date.
        local iso_norm="$iso"
        if [[ "$iso_norm" =~ ^([0-9T:-]+)([+-][0-9]{2}):([0-9]{2})$ ]]; then
            iso_norm="${BASH_REMATCH[1]}${BASH_REMATCH[2]}${BASH_REMATCH[3]}"
        fi
        # Try ISO with 'Z' first, then with numeric timezone offset.
        epoch="$(date -j -f "%Y-%m-%dT%H:%M:%SZ" "$iso_norm" +%s 2>/dev/null || true)"
        if [[ ! "$epoch" =~ ^[0-9]+$ ]]; then
            epoch="$(date -j -f "%Y-%m-%dT%H:%M:%S%z" "$iso_norm" +%s 2>/dev/null || true)"
        fi
    else
        epoch="$(date -d "$iso" +%s 2>/dev/null || true)"
    fi

    if [[ ! "$epoch" =~ ^[0-9]+$ ]]; then
        printf "%s" "$iso"
        return
    fi

    local diff=$(( now_epoch - epoch ))
    if (( diff >= 0 && diff < 86400 )); then
        # Same-day-ish: show local time only.
        if [[ "$date_mode" == "bsd" ]]; then
            local iso_norm="$iso"
            if [[ "$iso_norm" =~ ^([0-9T:-]+)([+-][0-9]{2}):([0-9]{2})$ ]]; then
                iso_norm="${BASH_REMATCH[1]}${BASH_REMATCH[2]}${BASH_REMATCH[3]}"
            fi
            date -j -f "%Y-%m-%dT%H:%M:%SZ" "$iso_norm" "+%I:%M %p" 2>/dev/null || \
            date -j -f "%Y-%m-%dT%H:%M:%S%z" "$iso_norm" "+%I:%M %p" 2>/dev/null || \
            printf "%s" "$iso"
        else
            date -d "$iso" "+%I:%M %p" 2>/dev/null || printf "%s" "$iso"
        fi
    else
        # Older than a day: show date only.
        if [[ "$date_mode" == "bsd" ]]; then
            local iso_norm="$iso"
            if [[ "$iso_norm" =~ ^([0-9T:-]+)([+-][0-9]{2}):([0-9]{2})$ ]]; then
                iso_norm="${BASH_REMATCH[1]}${BASH_REMATCH[2]}${BASH_REMATCH[3]}"
            fi
            date -j -f "%Y-%m-%dT%H:%M:%SZ" "$iso_norm" "+%Y-%m-%d" 2>/dev/null || \
            date -j -f "%Y-%m-%dT%H:%M:%S%z" "$iso_norm" "+%Y-%m-%d" 2>/dev/null || \
            printf "%s" "$iso"
        else
            date -d "$iso" "+%Y-%m-%d" 2>/dev/null || printf "%s" "$iso"
        fi
    fi
}

git_status_for_repo() {
    # NOTE: This function is written to avoid 'mapfile' for portability
    # with macOS's older /bin/bash. It could be simplified to use
    # 'mapfile' when running under bash 4+.
    local repo_name="$1"
    local path="$repo_name"

    if [[ ! -d "$path/.git" ]]; then
        echo "not-cloned"
        return 0
    fi

    pushd "$path" >/dev/null 2>&1 || {
        echo "ERR" "!"
        return 0
    }

    local porcelain
    porcelain="$(git status --porcelain=v1 2>/dev/null || true)"
    local dirty="false"
    if [[ -n "$porcelain" ]]; then
        dirty="true"
    fi

    local upstream
    upstream="$(git rev-parse --abbrev-ref --symbolic-full-name @{u} 2>/dev/null || true)"
    local ahead=0
    local behind=0
    if [[ -n "$upstream" ]]; then
        local counts
        counts="$(git rev-list --left-right --count "$upstream"...HEAD 2>/dev/null || echo "0 0")"
        local counts_one_line="${counts//$'\n'/ }"
        local counts_escaped="${counts_one_line//\"/\\\"}"
        debug_log "run1" "H3" "ghls:git_counts" "upstream counts" "$(printf '{"repo":"%s","upstream":"%s","countsRaw":"%s"}' \
            "$repo_name" "$upstream" "$counts_escaped")"
        # Split counts on whitespace so it works whether git uses spaces or tabs.
        set -- $counts
        behind="${1:-0}"
        ahead="${2:-0}"
    fi

    popd >/dev/null 2>&1 || true

    local status_label
    if [[ "$dirty" == "false" && "$ahead" -eq 0 && "$behind" -eq 0 ]]; then
        status_label="clean"
    elif [[ "$dirty" == "true" && "$ahead" -eq 0 && "$behind" -eq 0 ]]; then
        status_label="dirty"
    elif [[ "$ahead" -gt 0 && "$behind" -eq 0 ]]; then
        status_label="ahead"
    elif [[ "$ahead" -eq 0 && "$behind" -gt 0 ]]; then
        status_label="behind"
    else
        status_label="diverged"
    fi

    echo "$status_label"
}

jq_output=""
if ! jq_output="$(jq -r \
    --arg user "$current_user" \
    "$jq_program | \"\(.name)\t\(.owner.login)\t\(.isPrivate)\t\(.updatedAt)\"" \
    <<<"$gh_json" 2>&1)"; then
    debug_log "run1" "H2" "ghls:jq" "jq failed" "$(printf '{"jqOutputPrefix":"%s"}' "${jq_output:0:120}")"
    echo "ghls: jq processing failed (see debug log)." >&2
    exit 1
fi

debug_log "run1" "H2" "ghls:jq" "jq succeeded" "$(printf '{"outputSample":"%s"}' "${jq_output:0:80}")"

seen_repos=""

while IFS=$'\t' read -r name owner is_private updated; do
    display_name="$name"
    if [[ "$owner" != "$current_user" ]]; then
        display_name="$owner/$name"
    fi

    local_path="$name"
    has_local=false
    if [[ -d "$local_path/.git" ]]; then
        has_local=true
    fi

    # Apply cutoff only to remote-only repos when not showing all.
    if [[ -n "${cutoff_iso:-}" && "$show_all" == false && "$has_local" == false && "$updated" < "$cutoff_iso" ]]; then
        continue
    fi

    seen_repos+=" $name"

    status_label="$(git_status_for_repo "$name")"

    # Decide how to render STATUS (text + optional color).
    status_text="$status_label"
    status_color=""
    if $color_enabled; then
        case "$status_label" in
            clean)
                status_color="$c_clean"
                ;;
            dirty|ahead|behind|diverged)
                status_color="$c_dirty"
                ;;
        esac
    fi

    if [[ "$status_label" == "not-cloned" ]]; then
        status_text="not-cloned"
    elif [[ "$status_label" == "ERR" ]]; then
        status_text="error"
        if $color_enabled; then
            status_color="$c_dirty"
        fi
    fi

    # Prefer local last-commit time when a local clone exists; otherwise fall back to GitHub's updatedAt.
    display_updated="$updated"
    if [[ "$has_local" == true ]]; then
        if pushd "$local_path" >/dev/null 2>&1; then
            local_last="$(git log -1 --format=%cI 2>/dev/null || echo "")"
            popd >/dev/null 2>&1 || true
            if [[ -n "$local_last" ]]; then
                display_updated="$local_last"
            fi
        fi
    fi

    formatted_updated="$(format_updated "$display_updated")"

    printf "%s%-${width_status}s %-${width_name}s %-${width_updated}s%s\n" \
        "$status_color" "$status_text" "$display_name" "$formatted_updated" "$c_reset"
done <<<"$jq_output"

# Include local-only git repos (no corresponding GitHub repo) regardless of age.
for d in */.git; do
    repo="${d%/.git}"
    # Skip if we've already printed this repo from the GitHub list.
    if [[ " $seen_repos " == *" $repo "* ]]; then
        continue
    fi

    display_name="$repo"
    status_label="$(git_status_for_repo "$repo")"

    status_text="$status_label"
    status_color=""
    if $color_enabled; then
        case "$status_label" in
            clean)
                status_color="$c_clean"
                ;;
            dirty|ahead|behind|diverged)
                status_color="$c_dirty"
                ;;
        esac
    fi

    if [[ "$status_label" == "not-cloned" ]]; then
        status_text="not-cloned"
    elif [[ "$status_label" == "ERR" ]]; then
        status_text="error"
        if $color_enabled; then
            status_color="$c_dirty"
        fi
    fi

    updated=""
    if pushd "$repo" >/dev/null 2>&1; then
        updated="$(git log -1 --format=%cI 2>/dev/null || echo "")"
        popd >/dev/null 2>&1 || true
    fi
    formatted_updated="$(format_updated "$updated")"

    printf "%s%-${width_status}s %-${width_name}s %-${width_updated}s%s\n" \
        "$status_color" "$display_name" "$status_text" "$formatted_updated" "$c_reset"
done

# Include local directories without a git repo or GitHub entry.
for d in */; do
    repo="${d%/}"
    # Skip if we've already printed this repo from the GitHub list or as a git repo.
    if [[ " $seen_repos " == *" $repo "* ]]; then
        continue
    fi
    if [[ -d "$repo/.git" ]]; then
        continue
    fi

    display_name="$repo"
    status_label="no-git"
    status_text="$status_label"
    status_color=""
    if $color_enabled; then
        status_color="$c_dirty"
    fi

    formatted_updated=""

    printf "%s%-${width_status}s %-${width_name}s %-${width_updated}s%s\n" \
        "$status_color" "$status_text" "$display_name" "$formatted_updated" "$c_reset"
done

